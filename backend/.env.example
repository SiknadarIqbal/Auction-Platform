# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/auction-platform

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_bucket_name

# Email Configuration (for verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=noreply@auctionplatform.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=5
PAYMENT_DEADLINE_HOURS=24
ANTI_SNIPING_MINUTES=5
MAX_AUCTION_EXTENSIONS=3
