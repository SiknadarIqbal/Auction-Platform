        "articles": {
            "intro": {
                "title": "المقدمة",
                "content": "تمثل هذه الشروط والأحكام اتفاقية ملزمة قانوناً بين المنصة وأي مستخدم. إن الوصول إلى المنصة أو التسجيل فيها أو استخدامها بأي شكل من الأشكال يمثل موافقة كاملة وغير مشروطة على هذه الشروط."
            },
            "definitions": {
                "title": "التعريفات",
                "items": [
                    "المنصة: الموقع الإلكتروني وأي تطبيقات تابعة له.",
                    "المستخدم: أي فرد أو كيان يصل إلى المنصة أو يستخدمها.",
                    "البائع: أي شخص طبيعي أو اعتباري يدرج منتجاً للمزاد.",
                    "المشتري: أي مستخدم يقدم عرضاً في المزاد.",
                    "المزاد: عملية تنافسية لتقديم العروض حيث يرتفع السعر حتى الإغلاق."
                ]
            },
            "nature": {
                "title": "طبيعة دور المنصة",
                "items": [
                    "توفر المنصة مكاناً تقنياً لإدراج المنتجات من خلال المزادات فقط.",
                    "المنصة لا تملك المنتجات المدرجة ولا تخزنها ولا تفحصها.",
                    "المنصة لا تعمل كوكيل أو وسيط للبائعين أو المشترين.",
                    "المنصة ليست طرفاً في أي عقد بيع يبرم بين المستخدمين.",
                    "توجد العلاقة التعاقدية حصرياً بين البائع والمشتري."
                ]
            },
            "seller": {
                "title": "مسؤوليات البائع",
                "items": [
                    "يقر البائع بالملكية القانونية أو التفويض القانوني للبيع.",
                    "البائع مسؤول وحده عن دقة الوصف.",
                    "يتحمل البائع المسؤولية القانونية الكاملة عن المنتج.",
                    "يوافق البائع على تعويض المنصة عن أي مطالبات."
                ]
            },
            "buyer": {
                "title": "مسؤوليات المشتري",
                "items": [
                    "يتحمل المشتري مسؤولية مراجعة تفاصيل المنتج قبل المزايدة.",
                    "تقديم العرض هو التزام ملزم قانوناً إذا تم الترسية.",
                    "يتحمل المشتري مسؤولية ترتيبات الدفع مباشرة مع البائع."
                ]
            },
            "fees": {
                "title": "الرسوم والتكاليف",
                "items": [
                    "التسجيل والاستخدام مجاني حالياً لفترة محدودة.",
                    "تحتفظ المنصة بالحق في فرض رسوم أو عمولات مستقبلية.",
                    "سيتم إخطار المستخدمين قبل تنفيذ أي رسوم."
                ]
            },
            "realestate": {
                "title": "استثناء العقارات",
                "content": "يمنع منعاً باتاً إدراج أو بيع العقارات (أراضي، مباني، وحدات سكنية) بالمزاد. سيتم إزالة مثل هذه الإدراجات فوراً."
            },
            "prohibited": {
